<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Create Recipe</title>
</head>
<body>
    <form action="/recipes/createrecipe" method="post">

        <h1>Create Recipe</h1>
        
        <!-- put a hidden email for primary key -->

        <!-- create tittle for recipe -->
        <label>Title :</label>
        <input type="text" name="title" placeholder="Enter Title" size="30" required>

        <br><br>

        <!-- create description for recipe -->
        <label>Description: </label>
        <textarea name="description" placeholder="Enter desctiption" required></textarea>

        <br><br>
        <!-- Upload image for recipe -->
        <label for="imageUpload">Choose an image to upload:</label>
        <input type="text" id="imageUpload" name="image">
        <button type="button" onclick="uploadImage()">Upload Image</button>
        <img id="preview" src="#" alt="Image Preview" style="display:none;" required><br>


        <br><br>

        <!-- create ingredient array for recipe -->
        <button type="button" onclick="addIngredient()">Add Ingredient</button>
        <br><br>
        <div id="add_ingredients">
            <label>Ingredient: </label>
            <input type="text" name="ingredient[]" placeholder="Enter item" required>
        </div>

        <br><br>
        
        <!-- create steps array for recipe -->
        <button type="button" onclick="addStep()">Add Steps</button>
        <br><br>
        <div id="add_step">
            <label>Step 1: </label>
            <textarea name="steps[]" placeholder="Enter step" required></textarea>
        </div>


        <br><br><br>
        <button type="submit">Submit</button>

    </form>

    <script>
        let ingredientCount =1
        let stepCount=1
        function addIngredient() {
            //ingredientCount ++

            // Change getElementByName to getElementById
            const container = document.getElementById("add_ingredients");

            // 1. Create a wrapper div for the row
            const div = document.createElement("div"); // Wrap in a div for a new line
            div.className = "ingredient-row";

            // 2. Create the label
            const label = document.createElement("label");// wrap a label 
            label.textContent = "Ingredient" +  ": ";//fill the label

            // 3. Create the input
            const input = document.createElement("input");
            input.type = "text";
            input.name = "ingredient[]";
            input.placeholder = "Enter item";

            // 4. Create the Remove button
            const removeBtn = document.createElement("button");
            removeBtn.textContent = "Remove";
            removeBtn.type = "button";
            removeBtn.style.marginLeft = "10px";
    
            // 5. Add the click event to delete this specific row
            removeBtn.onclick = function() {
            div.remove();
            }

            // 6. Assemble and append
            div.appendChild(label)
            div.appendChild(input);
            div.appendChild(removeBtn);
            container.appendChild(div);
            }
        
        function addStep() {
            stepCount ++

            // Change getElementByName to getElementById
            const container = document.getElementById("add_step");
            

            const div = document.createElement("div"); // Wrap in a div for a new line
            div.className = "step-row";
            const label = document.createElement("label");// wrap a label 
            label.textContent = "Step " + stepCount + ": ";//fill the label

            const input = document.createElement("textarea");
            input.name = "steps[]";
            input.placeholder = "Enter step";

            const removeBtn = document.createElement("button");
            removeBtn.textContent = "Remove";
            removeBtn.type = "button";
            removeBtn.style.marginLeft = "10px";

            removeBtn.onclick = function() {
            div.remove();
            }

            div.appendChild(label)
            div.appendChild(input);
            div.appendChild(removeBtn);
            container.appendChild(div);
            }
        
        function uploadImage(){
            // 1. Get the URL string from the text input
            const imageUrl = document.getElementById('imageUpload').value;
    
            // 2. Select the preview image element
            const preview = document.getElementById('preview');

            if (imageUrl) {
                // 3. Set the image source to the provided link 
                preview.src = imageUrl;
        
                // 4. Make the image visible 
                preview.style.display = 'block';
        
                // Set a consistent width
                preview.style.width = '300px';
            } 
        }


        
    </script>
</body>
</html>