<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Our Cookbook</title>

    <style>
        /* CSS (no comments as requested) */
        body {
            font-family: Arial, sans-serif;
            margin: 0;
            background: #f5f5f5;
        }

        .navbar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            background: #ff7f50;
            padding: 15px 30px;
            color: white;
        }

        .navbar a {
            color: white;
            text-decoration: none;
            margin-left: 15px;
            font-weight: bold;
        }

        .navbar a:hover {
            text-decoration: underline;
        }

        .admin-badge {
            color: gold;
            font-weight: bold;
        }

        .hero {
            text-align: center;
            padding: 80px 20px;
            background: white;
        }

        .hero h1 {
            font-size: 40px;
            margin-bottom: 10px;
        }

        .hero p {
            color: #555;
            font-size: 18px;
        }

        .btn {
            display: inline-block;
            margin: 10px;
            padding: 10px 20px;
            background: #ff7f50;
            color: white;
            text-decoration: none;
            border-radius: 5px;
        }

        .btn:hover {
            background: #ff5722;
        }

        .links {
            text-align: center;
            margin-top: 40px;
        }

        .links a {
            display: inline-block;
            margin: 10px;
            padding: 10px 20px;
            background: white;
            border: 1px solid #ddd;
            border-radius: 5px;
            text-decoration: none;
            color: #333;
        }

        .links a:hover {
            background: #eee;
        }
    </style>
</head>
<body>

    <!-- Navbar section: shows app title + user-related actions -->
    <div class="navbar">

        <!-- Left side: application title -->
        <div>
            <strong>🍳 Haidil, Qing Rui, Ashrel, Sheng Ming, Casper, Ronald's Cookbook</strong>
        </div>

        <!-- Right side: dynamic content depending on login status -->
        <div>

            <!-- Check if user is logged in -->
            <% if (user) { %>

                <!-- If user is admin, show admin badge -->
                <% if (user.role === 'admin') { %>
                    <span class="admin-badge">👑 ADMIN</span>: <%= user.username %>
                <% } else { %>
                    <!-- Otherwise show normal user -->
                    👤 <%= user.username %>
                <% } %>

                <!-- Common actions available to all logged-in users -->
                <a href="/authentication/logout">Logout</a>
                <a href="/authentication/update">Update Account</a>
                <a href="/authentication/delete">Delete Account</a>

                <!-- Show Admin Panel button ONLY if user is admin -->
                <% if (user.role === 'admin') { %>
                    <a href="/authentication/admin-profile">Admin Panel</a>
                <% } %>

            <% } else { %>

                <!-- If user is NOT logged in, show auth options -->
                <a href="/authentication/register">Register</a>
                <a href="/authentication/login">Login</a>

            <% } %>
        </div>
    </div>

    <!-- Hero section: main landing content -->
    <div class="hero">

        <!-- Main heading -->
        <h1>Welcome to our Cookbook!</h1>

        <!-- Short description -->
        <p>Discover, create, and share your favorite recipes 🍲</p>

        <!-- If user is not logged in, show call-to-action button -->
        <% if (!user) { %>
            <a href="/authentication/register" class="btn">Get Started</a>
        <% } %>

    </div>

    <!-- Main navigation links -->
    <div class="links">

        <!-- Link to view all recipes -->
        <a href="/recipes">View Recipes</a>

        <!-- Link to manage user's own recipes -->
        <a href="/myRecipes">Manage my recipes</a>

        <!-- Link to view shopping cart -->
        <a href="/cart">View My Shopping Cart</a>

    </div>

</body>
</html>