<!DOCTYPE html>
<html>
<head>
    <title>My Cart</title>
</head>
<body>
    <h1>Shopping Cart</h1>
    
    <% if (recipes && recipes.length > 0) { %>
        <p>You have <strong><%= totalItems %></strong> items across <strong><%= recipes.length %></strong> recipes:</p>
        
        <% recipes.forEach(recipe => { %>
            <div>
                <hr>
                <div>
                    <div>
                        <strong>📖 <%= recipe.recipeTitle %></strong>
                        <span>(<%= recipe.items.length %> items)</span>
                    </div>
                    <form method="POST" action="/cart/remove-recipe" style="display: inline;">
                        <input type="hidden" name="recipeId" value="<%= recipe.recipeId %>">
                        <button type="submit">Remove All</button>
                    </form>
                </div>
                
                <div>
                    <% recipe.items.forEach(item => { %>
                        <div>
                            <div>
                                <span>• <%= item.name %></span>
                            </div>
                            <form method="POST" action="/cart/remove-item" style="display: inline;">
                                <input type="hidden" name="itemId" value="<%= item.itemId %>">
                                <button type="submit">Remove</button>
                            </form>
                        </div>
                        <br>
                    <% }) %>
                </div>
            </div>
        <% }) %>
        
        <hr>
        <form method="POST" action="/cart/clear">
            <button type="submit">Clear All Recipes</button>
        </form>
        
    <% } else { %>
        <div>
            <p>Your cart is empty</p>
            <p>Browse recipes and add ingredients to your shopping list!</p>
        </div>
    <% } %>
    
    <br>
    <a href="/recipes">Continue Shopping</a>
</body>
</html>