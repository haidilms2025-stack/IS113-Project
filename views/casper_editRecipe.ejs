<!DOCTYPE html>
<html lang="en">
<head>
    <title>Update Recipe</title>
</head>
<body>
      <%  if(result.title){ %>
    <h3>Update recipe </h3>
    <form action="/update-recipe" method="POST">
        <table border="1">
            <tr>
                <th>Title :</th><td><%= result.title %></td>
            </tr>
            <tr>
                <th>Image: </th><td><%= result.image %></td>
            </tr>
            <tr>
                <th>Description:</th><td><input type="text" name="description" value = "<%= result.description %>"></td>
            </tr>
            <tr>
                <th>Ingredients:</th><td><input type="text" name="ingredients" value="<%= result.ingredients %>"></td>
            </tr>
            <tr>
                <th>Steps:</th><td><textarea name="steps" id="steps" value="<%result.steps%>"></textarea></td>
            </tr>
            <input type="hidden" name="email" value="<%= result.email %>">
            <input type="hidden" name="userName" value="<%= result.userName %>">
            <tr>
                <td colspan="2"><button type="submit">Update Recipe</button></td>
            </tr>
        </table>
     
        
    </form>
     <% } %>


<br><br>

        
   
    
</body>
</html>