<!DOCTYPE html>
<html>
<head>
    <title>Favourite Recipes</title>
    
</head>

<body>

<h1> <%= User.username%>'s Favourite Recipes</h1>


<div id="recipes-container">

<table border="1" cellpadding="10" align="center">
<%
for (let i = 0; i < user.favourites.length; i++) {
    let favourite = user.favourites[i];

    if (i % 4 === 0) { %>
        <tr>
<% } %>

    <td valign="top">
        <div>
    
            <h3>
                Title: <%= favourite.title %>
                
            </h3> 

            <h4>Author: <%= favourite.username %></h4>

            <img src="<%= favourite.image %>" width="200" height="200">

            
            <h4>
                Difficulty:
                <%
                    let fire = "";
                    for (let j = 0; j < favourite.difficulty; j++) {
                        fire += "🔥";
                    }
                %>
                <%= fire %>
            </h4>

            <p>Description: <%= favourite.description %></p>

            <p>
                <strong>Ingredients:</strong><br>
                <% favourite.ingredients.forEach((element, index) => { %> 
                    <%= index + 1 %>: <%= element %><br>
                <% }) %>
            </p>

            <p>
                <strong>Steps:</strong><br>
                <% favourite.steps.forEach((element, index) => { %> 
                    Step <%= index + 1 %>: <%= element %><br>
                <% }) %>
            </p>

            <form method="GET" action="/recipe/<%= favourite._id %>">
                <button type="submit">View Recipe</button>
            </form>

            <form method="get" action="/delete-favourites">
                <button type="submit">Remove from Favourites</button>
            </form>
            <br>

            

        </div>
    </td>

<% if (i % 4 === 3) { %>
        </tr>
<% } %>

<% } %>

<!-- Close last row if not full -->
<% if (recipes.length % 4 !== 0) { %>
    </tr>
<% } %>

</table>

</div>


</body>
</html>