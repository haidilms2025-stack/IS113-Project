<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Create Recipe</title>
    <style>
        /* Borrowed from index.ejs  */
        body {
            font-family: Arial, sans-serif;
            margin: 0;
            background: #f5f5f5;
            color: #333;
        }

        /* Navbar Style [cite: 29, 30, 31] */
        .navbar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            background: #ff7f50;
            padding: 15px 30px;
            color: white;
        }

        .navbar a {
            color: white;
            text-decoration: none;
            margin-left: 15px;
            font-weight: bold;
        }


        .container {
            max-width: 800px;
            margin: 40px auto;
            padding: 40px;
            background: white;
            border-radius: 8px;
            box-shadow: 0 4px 6px rgba(0,0,0,0.1);
        }

        h1 {
            color: #ff7f50;
            font-size: 32px;
            margin-bottom: 20px;
        }

        /* Form Elements */
        label, span {
            display: block;
            font-weight: bold;
            margin-bottom: 8px;
            margin-top: 15px;
        }

        input[type="text"], select {
            width: 100%;
            padding: 10px;
            border: 1px solid #ddd;
            border-radius: 5px;
            box-sizing: border-box; /* Ensures padding doesn't affect width */
        }

        #steps_list {
            padding-left: 30px; 
            margin-top: 10px;
        }
        .step-row {
            display: list-item; 
            list-style-type: decimal; /* Ensures 1, 2, 3... numbering */
            margin-bottom: 20px;
            padding-left: 10px;
        }
        .step-row textarea {
            width: 80%; /* Adjusted to leave space for the button */
            vertical-align: middle;
            display: inline-block;
        }
        .step-row .btn-secondary {
            vertical-align: middle;
            margin-left: 10px;
            width: auto;
        }        
        /* Buttons  */
        .btn {
            display: inline-block;
            padding: 10px 20px;
            background: #ff7f50;
            color: white;
            text-decoration: none;
            border-radius: 5px;
            border: none;
            cursor: pointer;
            font-weight: bold;
            margin-top: 10px;
        }

        .btn:hover {
            background: #ff5722;
        }

        .btn-secondary {
            background: #eee;
            color: #333;
            border: 1px solid #ddd;
        }

        .btn-secondary:hover {
            background: #ddd;
        }

        .ingredient-row {
            display: flex;
            gap: 10px;
            align-items: center;
            margin-bottom: 10px;
        }

        .star-rating {
            display: flex;
            gap: 10px;
            font-size: 20px;
        }

        #preview {
            margin-top: 15px;
            border-radius: 5px;
            border: 1px solid #ddd;
        }
    </style>
</head>
<body>

    <div class="navbar">
        <div><strong>🍳 Cookbook</strong></div>
        <div>
            <% if (user) { %>
                👤 <%= user.username %>
                <a href="/authentication/logout">Logout</a>
            <% } %>
            <a href="/">Home</a>
        </div>
    </div>

    <div class="container">
        <form action="/myRecipes/create-recipe" method="post">
            <h1>Create Recipe</h1>
            
            <input type="hidden" name="userName" value="<%=user.username%>">
            <input type="hidden" name="userEmail" value="<%=user.email%>">
            
            <label>Title</label>
            <input type="text" name="title" placeholder="Enter Title" required>

            <label>Description</label>
            <textarea name="description" placeholder="What makes this dish special?" required></textarea>

            <label>Difficulty (1-5)</label>
            <div class="star-rating">
                <input type="radio" id="star5" name="difficulty" value="1" required/><label for="star5">1★</label>
                <input type="radio" id="star4" name="difficulty" value="2" /><label for="star4">2★</label>
                <input type="radio" id="star3" name="difficulty" value="3" /><label for="star3">3★</label>
                <input type="radio" id="star2" name="difficulty" value="4" /><label for="star2">4★</label>
                <input type="radio" id="star1" name="difficulty" value="5" /><label for="star1">5★</label>
            </div>

            <label>Recipe Image URL</label>
            <div style="display: flex; gap: 10px;">
                <input type="text" id="imageUpload" name="image" placeholder="Paste image URL here">
                <button type="button" class="btn" onclick="uploadImage()">Preview</button>
            </div>
            <img id="preview" src="#" alt="Image Preview" style="display:none; width:300px;">

            <hr style="margin: 30px 0; border: 0; border-top: 1px solid #eee;">

            <div id="add_ingredients">
                <label>Ingredients</label>
                <div class="ingredient-row">
                    <input type="text" name="ingredient[]" placeholder="Enter item" required>
                </div>
            </div>
            <button type="button" class="btn btn-secondary" onclick="addIngredient()">+ Add Ingredient</button>

            <br><br>

            <div id="add_step">
                <span>Steps</span>
                <ol id="steps_list">
                    <li class="step-row">
                    <textarea name="steps[]" placeholder="Step description" required></textarea>
                </li>
                </ol>
                
            </div>
            <button type="button" class="btn btn-secondary" onclick="addStep()">+ Add Step</button>

            <div style="margin-top: 40px; text-align: center;">
                <button type="submit" class="btn" style="font-size: 18px; padding: 15px 40px;">Publish Recipe</button>
                <br><br>
                <a href="/" style="color: #555;">Return to home page</a>
            </div>
        </form>
    </div>

    <script>
        //let ingredientCount =1
        function addIngredient() {
            //ingredientCount ++

            // Change getElementByName to getElementById
            const container = document.getElementById("add_ingredients");

            // 1. Create a wrapper div for the row
            const div = document.createElement("div"); // Wrap in a div for a new line
            div.className = "ingredient-row";

            // 2. Create the label
            const label = document.createElement("label");// wrap a label 
            label.textContent = "Ingredient" +  ": ";//fill the label

            // 3. Create the input
            const input = document.createElement("input");
            input.type = "text";
            input.name = "ingredient[]";
            input.placeholder = "Enter item";

            // 4. Create the Remove button
            const removeBtn = document.createElement("button");
            removeBtn.textContent = "Remove";
            removeBtn.type = "button";
            removeBtn.style.marginLeft = "10px";
    
            // 5. Add the click event to delete this specific row
            removeBtn.onclick = function() {
            div.remove();
            }

            // 6. Assemble and append
            div.appendChild(label)
            div.appendChild(input);
            div.appendChild(removeBtn);
            container.appendChild(div);
            }
        
        function addStep() {

            // Select the ordered list
            const container = document.getElementById("steps_list");
            
            const li = document.createElement("li"); // Wrap in a div for a new line
            li.className = "step-row";

            const input = document.createElement("textarea");
            input.name = "steps[]";
            input.placeholder = "Step description";

            const removeBtn = document.createElement("button");
            removeBtn.textContent = "Remove";
            removeBtn.type = "button";
            removeBtn.className = "btn-secondary"; // Optional: reuse your CSS class
            removeBtn.style.marginLeft = "10px";

            removeBtn.onclick = function() {
            li.remove();
            };

            li.appendChild(input);
            li.appendChild(removeBtn);
            container.appendChild(li);
            }
        
        function uploadImage(){
            //Get the URL string from the text input
            const imageUrl = document.getElementById('imageUpload').value;
    
            //Select the preview image element
            const preview = document.getElementById('preview');

            if (imageUrl) {
                //Set the image source to the provided link 
                preview.src = imageUrl;

                //Image loaded successfully
                preview.onload = function () {
                //Make the image visible
                preview.style.display = 'block';
                // Set a consistent width
                preview.style.width = '300px';
                };
                
                // Image failed to load 
                preview.onerror = function () {
                preview.style.display = 'none';
                alert("Image failed to load!");
                };  
            } 
            preview.style.display = 'none';

        }


        
    </script>
</body>
</html>