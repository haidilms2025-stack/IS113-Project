<!DOCTYPE html>
<html>
<head>
    <title>Update Account</title>
    <style>
        body {
            font-family: Arial;
            background: #f5f5f5;
            text-align: center;
        }

        .container {
            background: white;
            padding: 30px;
            margin: 100px auto;
            width: 300px;
            border-radius: 10px;
        }

        input {
            width: 90%;
            padding: 10px;
            margin: 10px 0;
        }

        button {
            padding: 10px 20px;
            background: #ff7f50;
            color: white;
            border: none;
            cursor: pointer;
        }

        button:hover {
            background: #ff5722;
        }

        .error {
            color: red;
        }
    </style>
</head>
<body>

<div class="container">
    <h2>Update Account</h2>

    <% if (error) { %>
        <p class="error"><%= error %></p>
    <% } %>

    <form action="/authentication/update" method="POST">
        <input type="text" name="username" placeholder="New Username"><br>
        <input type="password" name="password" placeholder="New Password"><br>
        <button type="submit">Update</button>
    </form>
</div>

</body>
</html>