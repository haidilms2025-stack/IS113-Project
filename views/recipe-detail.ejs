<!DOCTYPE html>
<html>
<head>
    <title><%= recipe.title %></title>
    <style>
        body {
            font-family: Arial, sans-serif;
            margin: 20px;
            background-color: #f5f5f5;
        }
        .recipe-container {
            background-color: white;
            padding: 30px;
            border-radius: 8px;
            max-width: 800px;
            margin: 0 auto;
            box-shadow: 0 2px 8px rgba(0,0,0,0.1);
        }
        .recipe-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
            border-bottom: 2px solid #eee;
            padding-bottom: 15px;
        }
        .recipe-title {
            margin: 0;
        }
        .recipe-actions {
            display: flex;
            gap: 10px;
        }
        .recipe-image {
            width: 100%;
            max-width: 400px;
            height: auto;
            border-radius: 8px;
            margin: 20px 0;
        }
        .recipe-info {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
            margin: 20px 0;
        }
        .info-item {
            padding: 10px;
            background-color: #f9f9f9;
            border-radius: 4px;
        }
        .info-label {
            font-weight: bold;
            color: #333;
        }
        .ingredients, .steps, .reviews {
            margin: 30px 0;
        }
        .ingredients h3, .steps h3, .reviews h3 {
            border-bottom: 2px solid #ddd;
            padding-bottom: 10px;
            margin-bottom: 15px;
        }
        .ingredient-item, .step-item, .review-item {
            margin: 10px 0;
            padding: 10px;
            background-color: #f9f9f9;
            border-left: 4px solid #4CAF50;
        }
        textarea {
            height: 100px;
            resize: vertical;
        }
        button {
            padding: 10px 20px;
            border: none;
            border-radius: 4px;
            cursor: pointer;
            font-size: 14px;
            transition: background-color 0.3s;
        }
        .btn-primary {
            background-color: #4CAF50;
            color: white;
        }
        .btn-primary:hover {
            background-color: #45a049;
        }
        .btn-secondary {
            background-color: #2196F3;
            color: white;
        }
        .btn-secondary:hover {
            background-color: #0b7dda;
        }
        .btn-danger {
            background-color: #f44336;
            color: white;
        }
        .btn-danger:hover {
            background-color: #da190b;
        }
        .rating-section {
            margin: 20px 0;
        }
        .modal {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0,0,0,0.5);
            align-items: center;
            justify-content: center;
            z-index: 1000;
        }
        .modal.active {
            display: flex;
        }
        .modal-content {
            background: white;
            padding: 30px;
            border-radius: 8px;
            text-align: center;
            box-shadow: 0 4px 6px rgba(0,0,0,0.2);
        }
        .modal-content h2 {
            margin-top: 0;
        }
        .rating-options {
            margin: 20px 0;
        }
        .rating-options label {
            display: block;
            margin: 10px 0;
            cursor: pointer;
        }
    </style>
</head>
<body>
<div class="recipe-container">
    <div class="recipe-header">
        <h1 class="recipe-title"><%= recipe.title %></h1>
        <div class="recipe-actions">
            <form method="post" action="/recipes/favourites" style="display:inline;">
                <input type="hidden" name="recipeId" value="<%= recipe._id %>">
                <button class="btn-secondary" type="submit">❤️ Add to Favourites</button>
            </form>
            <button class="btn-secondary" onclick="history.back()">← Back</button>
        </div>
    </div>

    <img src="<%= recipe.image %>" alt="<%= recipe.title %>" class="recipe-image">

    <div class="recipe-info">
        <div class="info-item">
            <span class="info-label">Author:</span><br>
            <%= recipe.username %>
        </div>
        <div class="info-item">
            <span class="info-label">Difficulty:</span><br>
            <%
                let fire = "";
                for (let j = 0; j < recipe.difficulty; j++) {
                    fire += "🔥";
                }
            %>
            <%= fire %>
        </div>
        <div class="info-item">
            <span class="info-label">Rating:</span><br>
            <%
                let stars = "";
                if (recipe.avgRating) {
                    let fullStars = Math.round(recipe.avgRating);
                    for (let j = 0; j < fullStars; j++) {
                        stars += "⭐";
                    }
                } else {
                    stars = "No ratings yet";
                }
            %>
            <%= stars %>
        </div>
        <div class="info-item">
            <span class="info-label">Description:</span><br>
            <%= recipe.description %>
        </div>
    </div>

    <div class="ingredients">
        <h3>Ingredients</h3>
        <% recipe.ingredients.forEach((ingredient, index) => { %>
            <div class="ingredient-item">
                <strong><%= index + 1 %>.</strong> <%= ingredient %>
            </div>
        <% }) %>
    </div>

    <div class="steps">
        <h3>Steps</h3>
        <% recipe.steps.forEach((step, index) => { %>
            <div class="step-item">
                <strong>Step <%= index + 1 %>:</strong> <%= step %>
            </div>
        <% }) %>
    </div>

    <div class="reviews">
        <h3>Reviews</h3>
        <% if(recipe.reviews.length === 0){ %>
            <div class="review-item">No Review</div>
        <% } else { %>
        <% recipe.reviews.forEach(review => { %>
            <div class="review-item">
                <strong><%= review.username %>:</strong>
                <p><%= review.review %></p>
            </div>
        <% })} %>
    </div>

    <div class="rating-section">
        <button class="btn" onclick="openRating('<%= recipe._id %>', `<%=recipe.hasRated%>`)">
        ⭐ Rate
    </button>
    </div>
    <div class="review-section">
            <button class="btn-primary" onclick="openReview('<%= recipe._id %>')">Give A Review</button>
    </div>
</div>

<div id="ratingModal" style="
    display:none;
    position:fixed;
    top:0; left:0;
    width:100%; height:100%;
    background:rgba(0,0,0,0.5);
">

    <div style="
        background:white;
        padding:20px;
        margin:10% auto;
        width:300px;
        text-align:center;
        border-radius:10px;
    ">
        <h2>Rate this recipe</h2>

        <form id="ratingForm" method="POST" action="recipes/rate">
            
            <input type="hidden" name="recipeId" id="recipeIdInput">

            <div>
                <input type="radio" name="rating" value="1"> ⭐ Poor<br>
                <input type="radio" name="rating" value="2"> ⭐⭐ Fair<br>
                <input type="radio" name="rating" value="3"> ⭐⭐⭐ Good<br>
                <input type="radio" name="rating" value="4"> ⭐⭐⭐⭐ Very Good<br>
                <input type="radio" name="rating" value="5"> ⭐⭐⭐⭐⭐ Excellent
            </div>
            
            <br>

            <p id="ratingMessage" style="color: green; display: none;">
                You already rated this recipe
            </p>

            <button class="btn" type="submit" name="action" value="submitRating" id="submitBtn">Submit</button>
            <button class="btn" type="submit" name="action" value="deleteRating" id="deleteBtn">Delete</button>
            <button class="btn" type="button" onclick="closeRating()">Cancel</button>

        </form>
    </div>
</div>

<div id="reviewModal" class="modal">
    <div class="modal-content">
        <h2>Review this recipe</h2>
        <form id="reviewForm" name="reviewForm" method="POST" action="/recipes/review">
            <input type="hidden" name="recipeId" id="reviewIdInput">
            
            <div class="recipe-review">
                    <textarea name="review" placeholder="Please input you review Here!" required></textarea>
                </div>  
            <br>
            <button type="submit" name="action" value="submitReview" class="btn-primary">
            <%= recipe.hasReviewed? "Update Review":" Submit Review" %> </button>
            <button type="submit" name="action" value="deleteReview" id="deleteBtn">Delete Review</button>
            <button type="button" class="btn-secondary" onclick="closeReview()">Close</button>
        </form>
    </div>
</div>

<script>
function openRating(recipeId, hasRated) {
    document.getElementById("ratingModal").style.display = "block";
    document.getElementById("recipeIdInput").value = recipeId;

    const submitBtn = document.getElementById("submitBtn");
    const deleteBtn = document.getElementById("deleteBtn");
    const displayMessage = document.getElementById("ratingMessage");

    if (hasRated === "true") {
        submitBtn.textContent = "Update";
        deleteBtn.style.display = "inline";
        displayMessage.style.display = "block";
    } else {
        submitBtn.textContent = "Submit";
        deleteBtn.style.display = "none";
        displayMessage.style.display = "none";
    }
}

function closeRating() {
    document.getElementById("ratingModal").style.display = "none";
}
function openReview(recipeId){
    document.getElementById("reviewModal").classList.add("active");
    document.getElementById("reviewIdInput").value = recipeId;
}
function closeReview() {
    document.getElementById("reviewModal").classList.remove("active");
}

// Close modal when clicking outside of it
document.getElementById("ratingModal").addEventListener("click", function(event) {
    if (event.target === this) {
        closeRating();
    }
});


</script>
</body>
</html>
