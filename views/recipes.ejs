<!DOCTYPE html>
<html>
<head>
    <title>Browse Recipes</title>

    <style>
        body {
            font-family: Arial, sans-serif;
            margin: 0;
            background: #f5f5f5;
        }

        /* Navbar */
        .navbar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            background: #ff7f50;
            padding: 15px 30px;
            color: white;
        }

        .navbar a {
            color: white;
            text-decoration: none;
            margin-left: 15px;
            font-weight: bold;
        }

        .navbar a:hover {
            text-decoration: underline;
        }

        /* Container */
        .container {
            padding: 20px;
        }

        /* Buttons */
        .btn {
            padding: 8px 12px;
            background: #ff7f50;
            color: white;
            border: none;
            border-radius: 5px;
            cursor: pointer;
        }

        .btn:hover {
            background: #ff5722;
        }

        /* Grid */
        .recipes-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
            gap: 20px;
            margin-top: 20px;
        }

        /* Card */
        .card {
            background: white;
            border-radius: 10px;
            padding: 15px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.1);
            transition: 0.2s;
        }

        .card:hover {
            transform: translateY(-5px);
        }

        .card img {
            width: 100%;
            height: 180px;
            object-fit: cover;
            border-radius: 8px;
        }

        .card h3 {
            margin: 10px 0 5px;
        }

        .card p {
            color: #555;
            font-size: 14px;
        }

        form {
            display: inline;
        }
    </style>
</head>

<body>

<!-- Navbar -->
<div class="navbar">

    <!-- Left side -->
    <div>
        <a href="/">Home</a>
        <a href="/recipes">Recipes</a>
        <a href="/cart">🛒 Cart</a>
        <a href="/myRecipes">Dashboard</a>
        <a href="/recipes/favourites">Favourites</a>
    </div>

    <!-- Right side -->
    <div>

        <% if (user) { %>

            <% if (user.role === 'admin') { %>
                <span class="admin-badge">👑 ADMIN</span>: <%= user.username %>
            <% } else { %>
                👤 <%= user.username %>
            <% } %>

            <a href="/authentication/logout">Logout</a>
            <a href="/authentication/update">Update Account</a>
            <a href="/authentication/delete">Delete Account</a>

            <% if (user.role === 'admin') { %>
                <a href="/authentication/admin-profile">Admin Panel</a>
            <% } %>

        <% } else { %>

            <a href="/authentication/register">Register</a>
            <a href="/authentication/login">Login</a>

        <% } %>

    </div>
</div>

<div class="container">

<h1>Browse Recipes</h1>

<!-- Search -->
<form method="POST" action="/recipes">
    <input type="text" name="titlesearch" value="<%= titlesearch ? titlesearch : '' %>" placeholder="Search recipes">
    <button class="btn" type="submit">Search</button>

    <input type="hidden" name="sort" value="<%= sort ? sort : '' %>">

    <button class="btn" type="button" onclick="window.location='/recipes'">Reset</button>
</form>

<br>

<!-- Sort -->
<form method="GET" action="/recipes">
    Sort by:
    <select name="sort">
        <option value="asc"<%= sort === 'asc' ? 'selected' : '' %>>Recipe (A-Z)</option>
        <option value="desc"<%= sort === 'desc' ? 'selected' : '' %>>Recipe (Z-A)</option>
        <option value="diffhigh"<%= sort === 'diffhigh' ? 'selected' : '' %>>Difficulty (High → Low)</option>
        <option value="difflow"<%= sort === 'difflow' ? 'selected' : '' %>>Difficulty (Low → High)</option>
        <option value="ratinghigh"<%= sort === 'ratinghigh' ? 'selected' : '' %>>Rating (High → Low)</option>
        <option value="ratinglow"<%= sort === 'ratinglow' ? 'selected' : '' %>>Rating (Low → High)</option>
    </select>

    <button class="btn" type="submit">Apply</button>
</form>

<hr>

<% if (isSearch && titlesearch) { %>
    <h2>Showing results for "<%= titlesearch %>"</h2>
<% } %>

<!-- Recipes -->
<div class="recipes-grid">

<% recipes.forEach(recipe => { %>

<div class="card">

    <% if(recipe.image){%>
    <img src="<%= recipe.image %>" alt="recipe image">
    <%}%>
    <h3><%= recipe.title %></h3>

    <p><strong>Author:</strong> <%= recipe.username %></p>

    <p>
        <strong>Rating:</strong>
        <%
            let stars = "";
            if (recipe.avgRating) {
                let fullStars = Math.floor(recipe.avgRating);
                for (let j = 0; j < fullStars; j++) {
                    stars += "⭐";
                }
            } else {
                stars = "No Rating";
            }
        %>
        <%= stars %>
    </p>

    <p>
        <strong>Difficulty:</strong>
        <%
            let fire = "";
            for (let j = 0; j < recipe.difficulty; j++) {
                fire += "🔥";
            }
        %>
        <%= fire %>
    </p>

    <p><%= recipe.description %></p>

    <br>

    <form method="GET" action="/recipes/<%= recipe._id %>">
        <button class="btn">View</button>
    </form>

    <form method="POST" action="/cart/add">
        <input type="hidden" name="recipeId" value="<%= recipe._id %>">
        <button class="btn">🛒</button>
    </form>

    <form method="POST" action="/recipes/favourites">
        <input type="hidden" name="recipeId" value="<%= recipe._id %>">
        <button class="btn">❤️</button>
    </form>

    <br><br>

    <button class="btn" onclick="openRating('<%= recipe._id %>', `<%=recipe.hasRated%>`)">
        ⭐ Rate
    </button>

</div>

<% }) %>

</div>

<% if (recipes.length === 0) { %>
    <p>No recipes found.</p>
<% } %>

</div>

<div id="ratingModal" style="
    display:none;
    position:fixed;
    top:0; left:0;
    width:100%; height:100%;
    background:rgba(0,0,0,0.5);
">

    <div style="
        background:white;
        padding:20px;
        margin:10% auto;
        width:300px;
        text-align:center;
        border-radius:10px;
    ">
        <h2>Rate this recipe</h2>

        <form id="ratingForm" method="POST" action="recipes/rate" on>
            
            <input type="hidden" name="recipeId" id="recipeIdInput">

            <div>
                <input type="radio" name="rating" value="1"> ⭐ Poor<br>
                <input type="radio" name="rating" value="2"> ⭐⭐ Fair<br>
                <input type="radio" name="rating" value="3"> ⭐⭐⭐ Good<br>
                <input type="radio" name="rating" value="4"> ⭐⭐⭐⭐ Very Good<br>
                <input type="radio" name="rating" value="5"> ⭐⭐⭐⭐⭐ Excellent
            </div>
            
            <br>

            <p id="ratingMessage" style="color: green; display: none;">
                You already rated this recipe
            </p>

            <p id="errorMsg" style="color:red;"></p>

            <button class="btn" type="submit" name="action" value="submitRating" onclick="return validateRating()" id="submitBtn">Submit</button>
            <button class="btn" type="submit" name="action" value="deleteRating" id="deleteBtn">Delete</button>
            <button class="btn" type="button" onclick="closeRating()">Cancel</button>

        </form>
    </div>
</div>

<script>
function openRating(recipeId, hasRated) {
    document.getElementById("ratingModal").style.display = "block";
    document.getElementById("recipeIdInput").value = recipeId;

    const submitBtn = document.getElementById("submitBtn");
    const deleteBtn = document.getElementById("deleteBtn");
    const displayMessage = document.getElementById("ratingMessage");

    if (hasRated === "true") {
        submitBtn.textContent = "Update";
        deleteBtn.style.display = "inline";
        displayMessage.style.display = "block";
    } else {
        submitBtn.textContent = "Submit";
        deleteBtn.style.display = "none";
        displayMessage.style.display = "none";
    }
}

function closeRating() {
    document.getElementById("ratingModal").style.display = "none";
}

function validateRating() {
    const rating = document.querySelector('input[name="rating"]:checked');
    const errorMsg = document.getElementById("errorMsg");

    if (!rating) {
        errorMsg.textContent = "Please select a rating first.";
        return false;
    }

    errorMsg.textContent = "";
    return true;

}
</script>

</body>
</html>