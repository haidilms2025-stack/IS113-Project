<!DOCTYPE html>
<html>
<head>
    <title>Browse Recipes</title>
    
</head>

<body>

<h1>Browse Recipes</h1>


<form method="POST" action="/recipes">
    <input type="text" name="titlesearch" value="<%= titlesearch ? titlesearch : '' %>" placeholder="Search recipes">
    <button type="submit">Search</button>

     <input type="hidden" name="sort" value="<%= sort ? sort : '' %>">

    <button type="button" onclick="window.location='/recipes'">Reset</button>
</form>

<hr>

<div>
    <form method="GET" action="/recipes">
        Sort by:
        <select name="sort">
            <option value="asc"<%= sort === 'asc' ? 'selected' : '' %>>Author (A-Z)</option>
            <option value="desc"<%= sort === 'desc' ? 'selected' : '' %>>Author (Z-A)</option>
            <option value="diff"<%= sort === 'diff' ? 'selected' : '' %>>Difficulty</option>
        </select>

        <button type="submit">Apply</button>
    </form>
</div>

<hr>
<% if (isSearch && titlesearch) { %>
    <h1>Showing recipes for "<%= titlesearch %>"</h1>
    <hr>
<% } %>
<h2>Recipes</h2>
<hr>
<% if (recipes.length === 0) { %>
<p>No recipes found for "<%= titlesearch %>"</p>
<% } %>

<div id="recipes-container">

<table border="1" cellpadding="10" align="center">
<%
for (let i = 0; i < recipes.length; i++) {
    let recipe = recipes[i];

    if (i % 4 === 0) { %>
        <tr>
<% } %>

    <td valign="top">
        <div>
    
            <h3>
                Title: <%= recipe.title %>

                <form method="POST" action="/cart/add" style="display:inline;">
                    <input type="hidden" name="recipeId" value="<%= recipe._id %>">
                    <button type="submit">🛒</button>
                </form>

                <form method="POST" action="/favourites" style="display:inline;">
                    <input type="hidden" name="recipeId" value="<%= recipe._id %>">
                    <button type="submit">❤️</button>
                </form>
            </h3> 

            <h4>Author: <%= recipe.username %></h4>

            <img src="<%= recipe.image %>" width="200" height="200">

            <h4>
                Rating:
                <%
                    let stars = "";
                    if (recipe.avgRating) {
                        let fullStars = Math.round(recipe.avgRating);
                        for (let j = 0; j < fullStars; j++) {
                            stars += "⭐";
                        }
                    } else {
                        stars = "No Rating";
                    }
                %>
                <%= stars %>
            </h4>

            <h4>
                Difficulty:
                <%
                    let fire = "";
                    for (let j = 0; j < recipe.difficulty; j++) {
                        fire += "🔥";
                    }
                %>
                <%= fire %>
            </h4>

            <p>Description: <%= recipe.description %></p>

            <p>
                <strong>Ingredients:</strong><br>
                <% recipe.ingredients.forEach((element, index) => { %> 
                    <%= index + 1 %>: <%= element %><br>
                <% }) %>
            </p>

            <p>
                <strong>Steps:</strong><br>
                <% recipe.steps.forEach((element, index) => { %> 
                    Step <%= index + 1 %>: <%= element %><br>
                <% }) %>
            </p>

            <form method="GET" action="/recipe/<%= recipe._id %>">
                <button type="submit">View Recipe</button>
            </form>

            <br>

            <button type="button" onclick="openRating('<%= recipe._id %>')">
                ⭐ Give A Rating
            </button>

        </div>
    </td>

<% if (i % 4 === 3) { %>
        </tr>
<% } %>

<% } %>

<!-- Close last row if not full -->
<% if (recipes.length % 4 !== 0) { %>
    </tr>
<% } %>

</table>

</div>

<div id="ratingModal" style="
    display:none;
    position:fixed;
    top:0; left:0;
    width:100%; height:100%;
    background:rgba(0,0,0,0.5);
">

    <div style="
        background:white;
        padding:20px;
        margin:10% auto;
        width:300px;
        text-align:center;
    ">
        <h2>Rate this recipe</h2>

        <form id="ratingForm" method="POST" action="recipes/rate">
            
            <input type="hidden" name="recipeId" id="recipeIdInput">

            <div>
                <input type="radio" name="rating" value="1"> ⭐<br>
                <input type="radio" name="rating" value="2"> ⭐⭐<br>
                <input type="radio" name="rating" value="3"> ⭐⭐⭐<br>
                <input type="radio" name="rating" value="4"> ⭐⭐⭐⭐<br>
                <input type="radio" name="rating" value="5"> ⭐⭐⭐⭐⭐
            </div>

            <br>

            <button type="submit">Submit</button>
            <button type="button" onclick="closeRating()">Cancel</button>

        </form>
    </div>
</div>
</div>

<script>
function openRating(recipeId) {
    document.getElementById("ratingModal").style.display = "block";
    document.getElementById("recipeIdInput").value = recipeId;
}

function closeRating() {
    document.getElementById("ratingModal").style.display = "none";
}
</script>

</body>
</html>