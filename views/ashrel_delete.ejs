<!DOCTYPE html>
<html>
<head>
    <title>Delete Account</title>
    <style>
        body {
            font-family: Arial;
            background: #f5f5f5;
            text-align: center;
        }

        .box {
            background: white;
            padding: 30px;
            margin: 100px auto;
            width: 350px;
            border-radius: 10px;
        }

        button {
            padding: 10px 20px;
            background: red;
            color: white;
            border: none;
            cursor: pointer;
            margin-top: 10px;
        }

        button:hover {
            background: darkred;
        }

        .error {
            color: red;
        }
    </style>
</head>
<body>

<div class="box">
    <h2>⚠️ Delete Account</h2>
    <p>Are you sure you want to delete your account?</p>
    <p><strong>This action cannot be undone.</strong></p>

    <% if (error) { %>
        <p class="error"><%= error %></p>
    <% } %>

    <form action="/authentication/delete" method="POST">
        <button type="submit">Yes, Delete My Account</button>
    </form>

    <br>
    <a href="/">Cancel</a>
</div>

</body>
</html>