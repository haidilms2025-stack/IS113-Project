<!DOCTYPE html>
<html>

<head>

    <title>Login</title>

    <style>
        .error {
            color: red;
            margin-bottom: 10px;
        }
    </style>

</head>

<body>

    <h2>Login</h2>

    <% if(error){ %>
        <div class="error">
            <%= error %>
        </div>
        <% } %>

            <form action="/login" method="POST">

                Email<br>
                <input type="email" name="email"><br><br>

                Password<br>
                <input type="password" name="password"><br><br>

                <button type="submit">Login</button>

            </form>

            <br>

            <a href="/register">Register here</a>

</body>

</html>